# =======================================================
# Voice Interview Agent — Environment Variables
# 100% OFFLINE — No internet, no API keys, no costs!
# =======================================================

# ── Ollama Model ─────────────────────────────────────────
# Pull your chosen model first:
#   ollama pull llama3          (recommended, 4.7GB)
#   ollama pull llama3:8b       (lighter, faster)
#   ollama pull mistral         (great alternative)
#   ollama pull phi3            (very lightweight)
OLLAMA_MODEL=llama3

# ── Ollama Server URL ─────────────────────────────────────
# Default Ollama address — change only if you moved it
OLLAMA_BASE_URL=http://localhost:11434

# ── FastAPI Backend ───────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── Faster-Whisper (local STT) ────────────────────────────
# Model sizes: tiny | base | small | medium | large-v2
# "base" is a great balance of speed & accuracy
WHISPER_MODEL=base

# ── Audio ─────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# ── pyttsx3 TTS settings ──────────────────────────────────
# Speech rate (words per minute). Default 175. Range: 100-250
TTS_RATE=165
# Volume: 0.0 to 1.0
TTS_VOLUME=1.0
# Voice index (0 = first system voice, 1 = second, etc.)
# Run: python -c "import pyttsx3; e=pyttsx3.init(); [print(i,v.name) for i,v in enumerate(e.getProperty('voices'))]"
TTS_VOICE_INDEX=0

# ── Session ───────────────────────────────────────────────
TRANSCRIPT_DIR=transcripts
MAX_QUESTIONS=8
